# Application
APP_NAME=travelku
APP_ENV=development
APP_PORT=8080

# Database (REQUIRED - Must be set in .env)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_NAME=travelku
DB_SSL_MODE=disable

# JWT (REQUIRED - Generate: openssl rand -base64 32)
JWT_SECRET=your-secret-key-change-this-in-production

# Server
SERVER_TIMEOUT=30

# CORS
CORS_ALLOW_ORIGINS=*
